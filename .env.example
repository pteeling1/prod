# Auth0 Configuration
VITE_AUTH0_DOMAIN=your-app.us.auth0.com
VITE_AUTH0_CLIENT_ID=your_auth0_client_id_here
VITE_AUTH0_AUDIENCE=https://sizer.teeling.ai

# API Configuration
VITE_API_URL=https://sizer.teeling.ai/api
# For development:
# VITE_API_URL=http://localhost:3001/api

# Backend Configuration (Node.js server)
PORT=3001
AUTH0_DOMAIN=your-app.us.auth0.com
AUTH0_CLIENT_ID=your_auth0_client_id_here
AUTH0_AUDIENCE=https://sizer.teeling.ai
AUTH0_CLIENT_SECRET=your_auth0_client_secret_here

# Database Configuration
COSMOS_ENDPOINT=https://your-cosmos.documents.azure.com:443/
COSMOS_KEY=your_cosmos_master_key_here
COSMOS_DATABASE=ax-calculator
COSMOS_CONTAINER=configurations

# Or if using MongoDB Atlas instead:
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/ax-calculator

# Environment
NODE_ENV=production
# For development:
# NODE_ENV=development
